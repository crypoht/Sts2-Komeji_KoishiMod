{
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.char": "(Passes by unconsciously)",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.next": "Continue",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.ancient": "Hey! Strange girl, what are you doing?",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Koishi, we meet again. Take a gift before you go.",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "Koishi, why are you going to the top of the Spire?",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Respond",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "I don't know. I just suddenly got here!",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.next": "Continue",
  "DARV.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2.ancient": "My treasures also arrive here for reasons I do not understand.",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.char": "What a big fish.",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.next": "Continue",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.ancient": "Satori youkai...",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Adventure... defeat... the Architect.",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.next": "Continue",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.char": "Of course!",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "Again... satori youkai...",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Question",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "Huh? Why am I back again?",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.next": "Continue",
  "NEOW.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2.ancient": "These... help... adventure.",
  "NONUPEIPE.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient": "Cute girl, let me make you even more beautiful.",
  "NONUPEIPE.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "I am never stingy with blessings for cute girls.",
  "NONUPEIPE.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "If you are going to meet the Architect, you must not lack beautiful and deadly things.",
  "NONUPEIPE.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Continue",
  "NONUPEIPE.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "(Accepts unconsciously)",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient": "Satori youkai! Eyeballs! We are the same!",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.next": "Continue",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.char": "Can you read minds too?",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Koishi! Adventuring again!",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.next": "Continue",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.char": "Mr. Big Eyeball! Hello!",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "Koishi! Why! Adventure!",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Respond",
  "OROBAS.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "Hmm... I don't know?",
  "PAEL.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient": "Strange girl, your heart is even calmer than mine.",
  "PAEL.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.char": "(Passes by humming)",
  "PAEL.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.next": "Continue",
  "PAEL.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.ancient": "Perhaps you could be even quieter.",
  "PAEL.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.char": "Mr. Dragon! Mr. Dragon!",
  "PAEL.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Continue",
  "PAEL.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.ancient": "So you can be this noisy?",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient": "Girl! Your knife hides killing intent!",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.next": "Continue",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.char": "Koishi doesn't know.",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Girl! Your knife needs sharpening!",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "Fight me! Koishi Komeiji!",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Step forward",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "(Koishi used gorgeous danmaku)",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.next": "Continue",
  "TANX.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2.ancient": "That barely hurt! But it deserves praise!",
  "TEZCATARA.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient": "Little one, are you lost?",
  "TEZCATARA.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Would you like some hot cocoa, little one?",
  "TEZCATARA.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.next": "Taste",
  "TEZCATARA.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.char": "It's even better than my sister's hot cocoa!",
  "TEZCATARA.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "Is there another cute little one like you?",
  "TEZCATARA.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Continue",
  "TEZCATARA.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "Sister! My sister really is cute!",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient": "A girl from far away? I can help you.",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.next": "Continue",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.char": "Scary-looking mister!",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Will you sign this contract? Perhaps you could call your sister over to sign it too.",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "These contracts can help your adventure, for only a small price.",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Respond",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "A contract? My sister said I shouldn't sign things carelessly.",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.next": "Continue",
  "VAKUU.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2.ancient": "This generous contract is one your sister would accept.",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0r.char": "Are you the Architect?",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0r.next": "Continue",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1r.ancient": "A satori youkai? How rare.",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1r.next": "Continue",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-2r.char": "I'm here to beat you!",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-2r.next": "Continue",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-3r.ancient": "Go back where you belong.",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.char": "(Unconscious stab)",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.next": "Continue",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.ancient": "Again? Go back.",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0r.ancient": "Satori youkai, return to where you belong!",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0r.next": "Continue",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1r.char": "My adventure isn't over yet!",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1r.next": "Continue",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2r.ancient": "Then it should end now!",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.3-0r.char": "(Unconscious poke",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.3-0r.next": "Continue",
  "THE_ARCHITECT.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.3-1r.ancient": "Annoying!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.title": "Two Gods of Moriya",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.epithet": "Yasaka and Moriya",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.0-0r.ancient": "A worshipper?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.0-0r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.0-0r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.0-1r.ancient": "Did you bring any gifts?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.0-1r.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.1-0r.ancient": "Here to worship again? Take something with you.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.1-0r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.1-0r.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.1-1r.ancient": "Have you seen another green-haired shrine maiden? Sanae ran away from home again...",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.1-1r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.2-0.ancient": "You're asking what that thing on the mountain is? Oh, that's nuclear equipment.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.ANY.2-0.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient": "Isn't that Koishi from the Palace of the Earth Spirits? Why are you here?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.next": "Answer",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.char": "I want power like Okuu's!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-2.ancient": "That is not something to play around with!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-2.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Koishi, have you seen Sanae?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.next": "Answer",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.char": "Huh? The green shrine maiden? I don't know.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-2r.ancient": "Maybe we should ask the tengu...",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-2r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.char": "Running away from home? My sister says I do that all the time too.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.ancient": "You should at least tell your family before doing that!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2.ancient": "I'm hungry, Kanako.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-2.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-3.ancient": "I'm hungry too!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-3.next": "Offer",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-3.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-4.char": "This is the pudding my sister gave Koishi. (A bouncy eyeball wreathed in purple smoke.)",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.0-0.ancient": "Iron one, stop right there.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.0-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.0-0.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.0-1.ancient": "You look rather unfortunate.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.0-1.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.1-0r.ancient": "Take these with you, and complete your wish with Moriya's blessing.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.1-0r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.1-0r.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.1-1r.ancient": "If Sanae were here, she could perform the grand Moriya dance.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.1-1r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.2-0.ancient": "Still not done? Have you seen a green-haired shrine maiden?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.2-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.2-0.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.2-1.ancient": "If you see her, tell her the two gods at home are begging her to come back.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.IRONCLAD.2-1.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.0-0.ancient": "When did you arrive!? Even the tengu didn't notice?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.0-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.0-0.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.0-1.ancient": "If you're here to worship, put down the knife first.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.0-1.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.1-0r.ancient": "Next time you can knock out the tengu, but leave the kappa alone.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.1-0r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.1-0r.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.1-1r.ancient": "Have you seen a green-haired shrine maiden?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.1-1r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.1-1r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.1-2r.char": "(Shakes head)",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.2-0.ancient": "Hey! Don't play with frogs! They are not throwing weapons!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.2-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.2-0.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.2-1.ancient": "Take some things and go. If you see Sanae, remind her it's time to come home.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.SILENT.2-1.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.0-0.ancient": "A new kappa creation?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.0-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.0-0.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.0-1.char": "(Confused beeping)",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.0-1.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.0-2.ancient": "What a curious creation.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.0-2.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.1-0r.ancient": "Even the kappa behind the mountain can't fix you? I'm getting more and more curious.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.1-0r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.1-0r.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.1-1r.ancient": "Did the kappa do anything to you?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.1-1r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.1-1r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.1-2r.char": "(Beeping while remembering unpleasant memories)",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.2-0.ancient": "Could Sanae's miracle power fix you?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.2-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.2-0.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.2-1.ancient": "If you see her, tell her: I! Am! Hungry!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.DEFECT.2-1.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.0-0.ancient": "From Former Hell? Should we ask that cat to carry you back?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.0-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.0-0.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.0-1.char": "I'm on the road to revenge. What can you do for me?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.0-1.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.0-2.ancient": "Take whatever you like. Moriya's blessing.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.0-2.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.1-0r.ancient": "Is that big hand beside you your shikigami?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.1-0r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.1-0r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.1-1r.char": "It's my partner.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.2-0.ancient": "Back again? Still haven't succeeded in your revenge? Take some more.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.2-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.2-0.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.NECROBINDER.2-1.char": "Thanks.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.0-0.char": "I've come to worship!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.0-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.0-1.ancient": "Finally, a normal... normal worshipper?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.0-1.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.0-1.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.0-2.ancient": "At least one...",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.0-2.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.1-0r.char": "(Offers tribute)",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.1-0r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.1-1r.ancient": "Little king, thank you for your tribute. Moriya's blessing will always protect you.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.1-1r.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.1-1r.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.1-2r.ancient": "What an eye-opening fellow.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.1-2r.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-0.ancient": "The little king has returned.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-0.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-0.ancient.speaker": "Kanako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-1.ancient": "Have you seen a green-haired shrine maiden?",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-1.next": "Answer",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-1.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-2.char": "I've seen a green four-legged creature. It hopped around.",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-2.next": "Continue",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-3.ancient": "That was a frog!",
  "KOMEIJIKOISHI-MORIYA_TWO_GODS_KOISHI.talk.REGENT.2-3.ancient.speaker": "Suwako",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.title": "Reimu Hakurei",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.epithet": "Shrine Maiden of Paradise",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.ANY.0-0r.ancient": "Hey! You over there, what happened here?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.ANY.1-0r.ancient": "Me? Many people from Gensokyo have wandered into this tower lately. I'm here to investigate.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.ANY.2-0.ancient": "You want my blessing first? At least put some money in the offering box.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.char": "Miss Reimu! Miss Reimu!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.0-1.ancient": "Who are you?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.ancient": "Satori youkai, if you have nothing to do, hurry back home!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-0r.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.char": "Koishi's adventure isn't over! Miss Reimu, do you want to come too?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-1r.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.1-2r.ancient": "Marisa isn't here either. Bringing this one along should be fine.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.ancient": "Satori youkai, take this. The ones ahead are a bit dangerous.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-0.next": "Accept",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.KOMEIJIKOISHI-KOISHI_CHARACTER.2-1.char": "Thank you, Miss Reimu!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.IRONCLAD.0-0.ancient": "You really do carry an ominous air.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.IRONCLAD.1-0r.ancient": "Starting fights at the slightest disagreement. You're very Gensokyo. Take this. It'll help.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.IRONCLAD.2-0.ancient": "You have deep ties with that punchable demon. Too bad I can't remove the curses it gave you.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.0-0.ancient": "(Watches the Silent fly in and ambush her prey)",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.0-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.0-1.ancient": "Ambushes aren't a good habit.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.1-0r.ancient": "Do you kill everything you see?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.1-0r.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.1-1r.char": "......",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.1-1r.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.1-2r.ancient": "If you're mute, go see Eirin.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.2-0.ancient": "You have a very bad aura. Did you touch something evil?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.2-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.2-1.char": "......",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.2-1.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.SILENT.2-2.ancient": "I shouldn't have asked.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.0-0.ancient": "What is this? Did the kappa build it?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.0-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.0-1.char": "(Confused beeping)",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.1-0r.ancient": "You cleaned up all the bugs below? How diligent.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.1-0r.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.1-1r.char": "(Embarrassed beeping)",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.2-0.ancient": "Even the kappa can't fix you? What are you beeping about?!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.2-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.DEFECT.2-1.char": "(Dejected beeping)",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.0-0.ancient": "Why are there so many people covered in curses here?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.0-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.0-1.char": "These curses let me take revenge on the Architect!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.0-1.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.0-2.ancient": "I doubt the Architect could trick me into stopping you.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.1-0r.ancient": "Take these from your friend. If you can take down the mastermind behind this incident, all the better.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.1-0r.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.1-1r.char": "Osty and I will kill him.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.NECROBINDER.2-0.ancient": "A book caused you all to become like this? There are too many dangerous things here.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.0-0.ancient": "You look like a god tied to a chair.",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.0-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.0-1.char": "I am the future king!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.1-0r.ancient": "What are those two below you? Your attendants?",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.1-0r.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.1-1r.char": "They are my servants!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.2-0.char": "Shrine maiden, two gods are looking for you!",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.2-0.next": "Continue",
  "KOMEIJIKOISHI-HAKUREI_REIMU_KOISHI.talk.REGENT.2-1.ancient": "Huh? Another incident?"
}
